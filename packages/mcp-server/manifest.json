{
  "dxt_version": "0.2",
  "name": "droidrun-cloud-mcp",
  "version": "0.3.0",
  "description": "The official MCP Server for the Droidrun Cloud API",
  "author": {
    "name": "Droidrun Cloud",
    "email": "support@droidrun.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/droidrun/cloud-sdk-typescript.git"
  },
  "homepage": "https://github.com/droidrun/cloud-sdk-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.droidrun.ai/api-reference",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "DROIDRUN_CLOUD_API_KEY": "${user_config.DROIDRUN_CLOUD_API_KEY}"
      }
    }
  },
  "user_config": {
    "DROIDRUN_CLOUD_API_KEY": {
      "title": "apiKey",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
